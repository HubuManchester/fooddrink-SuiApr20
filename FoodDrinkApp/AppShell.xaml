<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    Title="NutriBite"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#FDE1E5, Dark=#1C1415}"
    Shell.ForegroundColor="{AppThemeBinding Light=#3D282A, Dark=#FDE1E5}"
    Shell.TitleColor="{AppThemeBinding Light=#3D282A, Dark=#FDE1E5}"
    Shell.UnselectedColor="{AppThemeBinding Light=#C6DAFA, Dark=#8A9AB8}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FDE1E5, Dark=#1C1415}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#FFBDC3, Dark=#FFBDC3}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#FFBDC3, Dark=#FFBDC3}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#C6DAFA, Dark=#8A9AB8}">

    <TabBar>
        <ShellContent
            Title="Foods"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Hardware"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FDE8EB, Dark=#140F10}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FDF3F4, Dark=#101215}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#FFBDC3, Dark=#703840}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#EACFE8, Dark=#504050}" Offset="0.72" />
                        <GradientStop Color="{AppThemeBinding Light=#C6DAFA, Dark=#304060}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <Label x:Name="NameLabel"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="#FFF0F3" />
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#FDE8EE" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8D0D5, Dark=#3D2E30}"
                    BackgroundColor="{AppThemeBinding Light=#FEFAFA, Dark=#1A1516}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition overview" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D97080, Dark=#FFBDC3}" />
                    <Label x:Name="MacroLabel" FontSize="16" TextColor="{AppThemeBinding Light=#8AA5D5, Dark=#C6DAFA}" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8D0D5, Dark=#3D2E30}" />
                    <Label x:Name="DescriptionLabel" FontSize="15" TextColor="{AppThemeBinding Light=#6E5C58, Dark=#D4C4C8}" />
                    <Label x:Name="AllergyLabel" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#C46070, Dark=#FFBDC3}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read summary"
                        BackgroundColor="#D97080"
                        TextColor="#FFFFFF"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        BackgroundColor="{AppThemeBinding Light=#FEFAFA, Dark=#1A1516}"
                        BorderColor="{AppThemeBinding Light=#E8D0D5, Dark=#3D2E30}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#D97080, Dark=#FFBDC3}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

            <Button Text="Vibration reminder"
                    BackgroundColor="#8AA5D5"
                    TextColor="#FFFFFF"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

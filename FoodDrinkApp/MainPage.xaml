<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FDE8EB, Dark=#140F10}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FDF3F4, Dark=#101215}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#F7ECEE, Dark=#0F1215}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Padding="20,18,20,18">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#FFBDC3, Dark=#703840}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#EACFE8, Dark=#504050}" Offset="0.62" />
                        <GradientStop Color="{AppThemeBinding Light=#C6DAFA, Dark=#304060}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.45" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="NutriBite"
                           FontSize="31"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Track nutrition, flavour, photos, and meal context in one place."
                           FontSize="15"
                           TextColor="#FFF0F3" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,3,0,0">
                        <Border BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Nutrition" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Photos" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Voice" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <!-- 摇一摇随机推荐指示条 + 数据源状态 -->
                    <Border x:Name="ShakeIndicator"
                            Grid.Row="3"
                            StrokeThickness="0"
                            BackgroundColor="#33FFFFFF"
                            Padding="10,7">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="3">
                            <Label x:Name="ShakeHintLabel"
                                   Text="📳 Shake your phone to discover a random healthy recipe"
                                   TextColor="#FFFFFF"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="DataSourceLabel"
                                   Grid.Row="1"
                                   Text="Data source: initializing..."
                                   TextColor="#FFFFFF"
                                   FontSize="10"
                                   HorizontalTextAlignment="Center"
                                   Opacity="0.8" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,6,0,0">
                        <Border StrokeThickness="1"
                                Stroke="#E8D0D5"
                                BackgroundColor="#FEFAFA"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#3D282A"
                                       PlaceholderColor="#9A7B75"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="#8AA5D5"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,0,16,18">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E8D0D5, Dark=#3D2E30}"
                                BackgroundColor="{AppThemeBinding Light=#FEFAFA, Dark=#1A1516}"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,5" Radius="14" Opacity="0.34" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="6,*">
                                <BoxView BackgroundColor="{AppThemeBinding Light=#FFBDC3, Dark=#FFBDC3}" />
                                <Grid Grid.Column="1" Padding="16" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                                    <Label Text="{Binding Name}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#3D282A, Dark=#FDE8EB}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#FDE8ED, Dark=#4A2D30}"
                                            Padding="10,5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#C46070, Dark=#FFBDC3}" />
                                    </Border>
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6E5C58, Dark=#D4C4C8}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#8AA5D5, Dark=#C6DAFA}" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding CategoryWithEmoji}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#D97080, Dark=#FFBDC3}" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="14,8"
                                                BackgroundColor="{AppThemeBinding Light=#D97080, Dark=#FFBDC3}"
                                                TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D181A}"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
